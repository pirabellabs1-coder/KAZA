# =============================================================
# KAZA - Variables d'Environnement
# =============================================================
# Copier ce fichier en .env.local et remplir les valeurs
# cp .env.example .env.local
# =============================================================

# -------------------------------------------------------------
# SUPABASE
# https://supabase.com/dashboard/project/_/settings/api
# -------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# -------------------------------------------------------------
# FEDAPAY (Paiements Mobile Money - principal)
# https://app.fedapay.com/dashboard/settings/api-keys
# -------------------------------------------------------------
FEDAPAY_PUBLIC_KEY=pk_sandbox_xxxxxxxxxxxxxxxx
FEDAPAY_SECRET_KEY=sk_sandbox_xxxxxxxxxxxxxxxx
FEDAPAY_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx
FEDAPAY_ENVIRONMENT=sandbox

# -------------------------------------------------------------
# KKIAPAY (Paiements - Fallback)
# https://app.kkiapay.me/dashboard/settings
# -------------------------------------------------------------
NEXT_PUBLIC_KKIAPAY_PUBLIC_KEY=xxxxxxxxxxxxxxxx
KKIAPAY_PRIVATE_KEY=xxxxxxxxxxxxxxxx
KKIAPAY_SECRET=xxxxxxxxxxxxxxxx
KKIAPAY_WEBHOOK_SECRET=
KKIAPAY_ENV=sandbox

# -------------------------------------------------------------
# ESCROW (Séquestre interne)
# -------------------------------------------------------------
ESCROW_DEFAULT_HOLD_DAYS=7

# -------------------------------------------------------------
# TWILIO (SMS OTP)
# https://console.twilio.com
# -------------------------------------------------------------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1234567890

# -------------------------------------------------------------
# RESEND (Emails transactionnels)
# https://resend.com/api-keys
# -------------------------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@kaza.com

# -------------------------------------------------------------
# MAPBOX (Cartes et Geocoding)
# https://account.mapbox.com/access-tokens
# -------------------------------------------------------------
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1Ijoixxxxxxxxxxxxxxxxxxxxxxxx

# -------------------------------------------------------------
# FIREBASE CLOUD MESSAGING (Push Notifications)
# https://console.firebase.google.com/project/_/settings/cloudmessaging
# -------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_FIREBASE_PROJECT_ID=kaza-xxxxxx
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=xxxxxxxxxxxx
FIREBASE_SERVER_KEY=AAAAxxxxxxxxxxxxxxxxxxxxxxxx

# -------------------------------------------------------------
# SENTRY (Monitoring - optionnel, V1+)
# https://sentry.io/settings/account/api/auth-tokens
# -------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxxx@o0.ingest.sentry.io/0
SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxxxxxxxxxxxxxx

# -------------------------------------------------------------
# APPLICATION
# -------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=KAZA
NODE_ENV=development

# === Notifications ===
FCM_SERVER_KEY=
RESEND_API_KEY=
NOTIFICATIONS_FROM_EMAIL=noreply@kaza.africa
NOTIFICATIONS_FROM_NAME=KAZA
